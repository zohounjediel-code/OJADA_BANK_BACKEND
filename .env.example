# Serveur
PORT=5000
NODE_ENV=development

# JWT - Changez cette clé secrète en production !
JWT_SECRET=ojada_bank_secret_key_changez_moi_en_production
JWT_EXPIRES_IN=7d

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/ojada_bank

# Email (Brevo API) - Meilleure délivrabilité, pas de spam
# Récupérez votre clé API sur https://app.brevo.com (Settings → SMTP & API → API keys)
BREVO_API_KEY=votre_cle_api_brevo
EMAIL_FROM=noreply@brevo.com

# URL du frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:3000

# Compte admin fixe (ne pas modifier)
ADMIN_USERNAME=jediel
ADMIN_PASSWORD=jediel
